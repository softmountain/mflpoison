{
  "metadata": {
    "dataset": "UCF101 multimodal 51-class subset",
    "purpose": "Group labels by likely visual similarity patterns for confusion analysis and experiment design",
    "grouping_basis": [
      "human pose similarity",
      "scene/background similarity",
      "object/instrument similarity",
      "action dynamics visible from frames"
    ],
    "notes": [
      "These are heuristic visual groups, not model-derived clusters.",
      "A label may fit multiple visual patterns, but each label is assigned to one primary group here for simplicity."
    ]
  },
  "groups": {
    "face_grooming_and_makeup": {
      "description": "Close-up face or upper-body actions with hands/tools near the face in indoor grooming scenes.",
      "labels": [
        "ApplyEyeMakeup",
        "ApplyLipstick",
        "BlowDryHair",
        "BrushingTeeth",
        "Haircut",
        "HeadMassage",
        "ShavingBeard"
      ]
    },
    "gymnastics_and_body_support": {
      "description": "Gymnastics apparatus, balance, inverted poses, body support, and controlled acrobatic movement.",
      "labels": [
        "BalanceBeam",
        "FloorGymnastics",
        "HandstandPushups",
        "HandstandWalking",
        "ParallelBars",
        "StillRings",
        "UnevenBars"
      ]
    },
    "ball_and_strike_actions": {
      "description": "Sports with throwing, striking, dunking, penalty actions, or racket/bat-like motion cues.",
      "labels": [
        "BasketballDunk",
        "Bowling",
        "CricketBowling",
        "CricketShot",
        "FieldHockeyPenalty",
        "FrisbeeCatch",
        "SoccerPenalty",
        "TableTennisShot"
      ]
    },
    "boxing_and_combat_practice": {
      "description": "Punching motions in boxing practice scenes with visually similar equipment and stance.",
      "labels": [
        "BoxingPunchingBag",
        "BoxingSpeedBag",
        "SumoWrestling"
      ]
    },
    "throwing_and_launch_actions": {
      "description": "Athletic launch or throw actions centered on whole-body power transfer and release motion.",
      "labels": [
        "Archery",
        "HammerThrow",
        "LongJump",
        "Shotput"
      ]
    },
    "music_performance": {
      "description": "Human instrument-playing scenes, often indoor or stage-like, distinguished mainly by instrument shape.",
      "labels": [
        "PlayingCello",
        "PlayingDaf",
        "PlayingDhol",
        "PlayingFlute",
        "PlayingSitar"
      ]
    },
    "indoor_fine_grained_manual_tasks": {
      "description": "Indoor object-manipulation or fine-grained hand actions with relatively static scenes.",
      "labels": [
        "CuttingInKitchen",
        "Knitting",
        "Typing",
        "WritingOnBoard"
      ]
    },
    "cleaning_and_tool_use": {
      "description": "Indoor actions involving household or workshop tools and repetitive arm motion.",
      "labels": [
        "Hammering",
        "MoppingFloor"
      ]
    },
    "water_air_and_outdoor_motion": {
      "description": "Outdoor motion-heavy scenes involving water, sky, or large environmental context.",
      "labels": [
        "CliffDiving",
        "FrontCrawl",
        "IceDancing",
        "Rafting",
        "SkyDiving",
        "Surfing"
      ]
    },
    "exercise_and_floor_mobility": {
      "description": "Bodyweight exercise or low-to-ground mobility actions without strong apparatus cues.",
      "labels": [
        "BabyCrawling",
        "BodyWeightSquats",
        "WallPushups"
      ]
    },
    "performance_and_group_motion": {
      "description": "Performance-style motion with strong costume, group, or choreographed scene cues.",
      "labels": [
        "BandMarching"
      ]
    },
    "small_object_or_subtle_event_actions": {
      "description": "Actions where the key cue may be a small object or subtle local event rather than full-body motion.",
      "labels": [
        "BlowingCandles"
      ]
    }
  },
  "high_confusion_priority_groups": [
    "face_grooming_and_makeup",
    "gymnastics_and_body_support",
    "ball_and_strike_actions",
    "music_performance",
